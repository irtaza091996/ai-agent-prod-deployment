# Copy this file to .env and fill in your values
# Never commit .env — it is listed in .gitignore

# Gemini model to use for the agents
MODEL="gemini-2.5-flash"

# URL of the zoo MCP server deployed in Lab 1
# Replace PROJECT_NUMBER with your actual Google Cloud project number
MCP_SERVER_URL=https://zoo-mcp-server-YOUR_PROJECT_NUMBER.europe-west1.run.app/mcp
