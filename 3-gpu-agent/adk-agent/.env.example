# Copy this file to .env and fill in your values
# Never commit .env — it is listed in .gitignore

# Your Google Cloud project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Region where services are deployed
GOOGLE_CLOUD_LOCATION=europe-west1

# Gemma model name (must match what was pulled in the Ollama Dockerfile)
GEMMA_MODEL_NAME=gemma3:270m

# URL of the deployed Ollama backend (set after deploying ollama-gemma3-270m-gpu)
OLLAMA_API_BASE=https://ollama-gemma3-270m-gpu-YOUR_PROJECT_NUMBER.europe-west1.run.app
